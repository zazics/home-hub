{
  "compilerOptions": {
    "lib": ["ES2020"],
    "types": ["node"],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true
  },
  "include": ["backend/src/**/*", "frontend/src/**/*"],
  "exclude": ["node_modules", "backend/dist", "backend/node_modules", "frontend/dist", "frontend/node_modules"]
}
